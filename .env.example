# ---- Telegram ----
# Required in production. Get it from @BotFather.
TELEGRAM_BOT_TOKEN=
# Public URL of the Mini App (Telegram Web App). HTTPS in production.
TELEGRAM_WEBAPP_URL=http://localhost:5173

# ---- App / Sessions ----
# Long random secret used to sign session tokens. REQUIRED in production.
APP_SECRET=
# Session token lifetime in seconds (default 1h).
SESSION_TTL_SECONDS=3600
# Telegram initData max age in seconds (default 1h).
INITDATA_MAX_AGE_SECONDS=3600
# Comma-separated list of allowed CORS origins (frontend URLs).
CORS_ORIGINS=http://localhost:5173
# Trusted hosts for production (Host header validation).
TRUSTED_HOSTS=

# ---- Database ----
# Async SQLAlchemy URL. Production should use postgresql+asyncpg.
DATABASE_URL=postgresql+asyncpg://crypto:crypto@localhost:5432/crypto_intel

# ---- Redis / Taskiq broker ----
REDIS_URL=redis://localhost:6379/0

# ---- Blockchain providers ----
# Active provider name. Supported: etherscan, mock
BLOCKCHAIN_PROVIDER=mock
# Etherscan API key (required when BLOCKCHAIN_PROVIDER=etherscan).
BLOCKCHAIN_API_KEY=
# Optional override for the Etherscan base URL (must be HTTPS, no credentials).
# Leave blank to use https://api.etherscan.io/api
BLOCKCHAIN_BASE_URL=
# Per-provider HTTP timeout in seconds.
PROVIDER_HTTP_TIMEOUT=10.0
# Max retries for retryable provider failures.
PROVIDER_MAX_RETRIES=4

# ---- AI provider ----
# Active AI provider. Supported: openai, mock
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_HTTP_TIMEOUT=20.0

# ---- Runtime ----
ENVIRONMENT=development
LOG_LEVEL=INFO
# Bypass auth for local dev only. NEVER set to true in production.
DEV_BYPASS_AUTH=false
